generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id          String   @id @default(cuid())
  anonymousId String?
  userId      String?
  goal        String
  mode        String
  title       String
  summary     String?
  source      String   @default("ai")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  snapshots            CourseSnapshot[]
  taskProgress         TaskProgress[]
  learningStepProgress LearningStepProgress[]
  learningCardProgress LearningCardProgress[]
  learningSessions     LearningSession[]
  courseProgress       CourseProgress?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([anonymousId])
  @@index([userId])
  @@index([updatedAt])
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  passwordHash        String
  membershipTier      String    @default("free")
  membershipStatus    String    @default("active")
  membershipStartedAt DateTime?
  membershipExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions UserSession[]
  courses  Course[]

  @@index([email])
  @@index([membershipTier])
}

model UsageCounter {
  id        String   @id @default(cuid())
  scopeId   String
  scopeType String
  type      String
  dateKey   String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scopeId, scopeType, type, dateKey])
  @@index([scopeId])
  @@index([type])
  @@index([dateKey])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model CourseProgress {
  id             String   @id @default(cuid())
  courseId       String   @unique
  anonymousId    String?
  userId         String?
  goal           String
  mode           String?
  overallPercent Int      @default(0)
  completedCount Int      @default(0)
  totalCount     Int      @default(0)
  lastVisitedUrl String?
  lastPageType   String?
  lastPhaseIndex Int?
  lastPhaseName  String?
  lastTopicIndex Int?
  lastTopicTitle String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([anonymousId])
  @@index([userId])
  @@index([updatedAt])
}

model CourseSnapshot {
  id        String   @id @default(cuid())
  courseId  String
  version   Int      @default(1)
  payload   Json
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model TaskProgress {
  id          String   @id @default(cuid())
  courseId    String?
  anonymousId String?
  goal        String
  mode        String?
  phaseIndex  Int
  phaseName   String
  taskIndex   Int
  taskTitle   String
  status      String   @default("not_started")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, taskIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
}

model LearningStepProgress {
  id          String   @id @default(cuid())
  courseId    String?
  anonymousId String?
  goal        String
  mode        String?
  phaseIndex  Int
  phaseName   String
  stepIndex   Int
  stepTitle   String
  status      String   @default("unset")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, stepIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
}

model LearningCardProgress {
  id          String   @id @default(cuid())
  courseId    String?
  anonymousId String?
  goal        String
  mode        String?
  phaseIndex  Int
  phaseName   String
  topicIndex  Int
  topicTitle  String
  status      String   @default("not_started")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, topicIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
}

model LearningSession {
  id           String   @id @default(cuid())
  courseId     String?
  anonymousId  String?
  goal         String
  mode         String?
  phaseIndex   Int
  phaseName    String
  topicIndex   Int
  topicTitle   String
  title        String
  summary      String?
  searchQuery  String?
  content      Json
  references   Json?
  fallbackUsed Boolean  @default(false)
  source       String   @default("ai")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, topicIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
  @@index([updatedAt])
}
