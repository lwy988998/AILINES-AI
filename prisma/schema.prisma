generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id          String   @id @default(cuid())
  anonymousId String?
  userId      String?
  goal        String
  mode        String
  title       String
  summary     String?
  source      String   @default("ai")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  snapshots            CourseSnapshot[]
  taskProgress         TaskProgress[]
  learningStepProgress LearningStepProgress[]
  learningCardProgress LearningCardProgress[]

  @@index([anonymousId])
  @@index([userId])
  @@index([updatedAt])
}

model CourseSnapshot {
  id        String   @id @default(cuid())
  courseId  String
  version   Int      @default(1)
  payload   Json
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model TaskProgress {
  id          String   @id @default(cuid())
  courseId    String?
  anonymousId String?
  goal        String
  mode        String?
  phaseIndex  Int
  phaseName   String
  taskIndex   Int
  taskTitle   String
  status      String   @default("not_started")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, taskIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
}

model LearningStepProgress {
  id          String   @id @default(cuid())
  courseId    String?
  anonymousId String?
  goal        String
  mode        String?
  phaseIndex  Int
  phaseName   String
  stepIndex   Int
  stepTitle   String
  status      String   @default("unset")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, stepIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
}

model LearningCardProgress {
  id          String   @id @default(cuid())
  courseId    String?
  anonymousId String?
  goal        String
  mode        String?
  phaseIndex  Int
  phaseName   String
  topicIndex  Int
  topicTitle  String
  status      String   @default("not_started")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, phaseIndex, topicIndex])
  @@index([anonymousId])
  @@index([goal])
  @@index([courseId])
  @@index([phaseIndex])
}
